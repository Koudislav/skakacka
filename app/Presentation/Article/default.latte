{block title}{$seo->getTitle()}{/block}
{block content}
<div n:class="$config['template_container_fluid'] ? container-fluid : container, content-container, !empty($colorScheme['bg_content']) ? 'bg-' . $colorScheme['bg_content'] : ''">
	{if $article->show_title}
		<h1>{$article->title}</h1>
	{/if}
	<div>
		{$articleContent|noescape}
	</div>
</div>
